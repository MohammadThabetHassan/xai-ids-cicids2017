{
  "project": "XAI-IDS: Explainable AI Intrusion Detection",
  "repo": "MohammadThabetHassan/xai-ids-cicids2017",
  "xai_methods": [
    "SHAP TreeExplainer",
    "LIME TabularExplainer"
  ],
  "models": [
    "XGBoost",
    "RandomForest",
    "LightGBM",
    "VotingEnsemble"
  ],
  "xcs": {
    "formula": "XCS = w1*Conf + w2*(1-Instab) + w3*Jaccard_SL",
    "weights": {
      "w1": 0.4,
      "w2": 0.3,
      "w3": 0.3
    },
    "threshold": 0.3
  },
  "cross_dataset_jaccard": 0.21626984126984125,
  "datasets": {
    "CICIDS2017": {
      "n_features": 20,
      "features": [
        "Fwd Seg Size Min",
        "Fwd IAT Total",
        "Fwd IAT Std",
        "Flow IAT Mean",
        "Fwd IAT Mean",
        "Avg Packet Size",
        "Packet Length Mean",
        "Packet Length Max",
        "Flow IAT Std",
        "Bwd IAT Std",
        "Bwd Packet Length Max",
        "Flow IAT Max",
        "Bwd Packet Length Min",
        "Flow Duration",
        "Fwd IAT Max",
        "Bwd Packet Length Mean",
        "Bwd IAT Max",
        "Packet Length Std",
        "Bwd Packet Length Std",
        "PSH Flag Count"
      ],
      "n_classes": 14,
      "classes": [
        "Benign",
        "Bot",
        "DDoS",
        "DoS GoldenEye",
        "DoS Hulk",
        "DoS Slowhttptest",
        "DoS slowloris",
        "FTP-Patator",
        "Infiltration",
        "PortScan",
        "SSH-Patator",
        "Web Attack \ufffd Brute Force",
        "Web Attack \ufffd Sql Injection",
        "Web Attack \ufffd XSS"
      ],
      "results": {
        "XGBoost": {
          "accuracy": 0.9965985537554486,
          "f1": 0.9964266910704263,
          "precision": 0.9963780726971228,
          "recall": 0.9965985537554486
        },
        "RandomForest": {
