]


def sample_parquet(path, n, label_candidates):
    """Load parquet and sample n rows — memory safe."""
    df = pd.read_parquet(path)
    df.columns = df.columns.str.strip()
    if n and len(df) > n:
        df = df.sample(n=n, random_state=42)
    return df


def sample_csv_chunked(path, n_per_file, label_candidates, encoding='utf-8'):
    """
    Read CSV in chunks, sample n_per_file rows total.
    NEVER loads the full file — critical for 1M+ row CSVs.
    """
    chunksize = 100_000
    collected = []
    total_read = 0
    try:
        for chunk in pd.read_csv(
            path, encoding=encoding,
            low_memory=False, chunksize=chunksize
        ):
            chunk.columns = chunk.columns.str.strip()
            chunk.replace([np.inf, -np.inf], np.nan, inplace=True)
            chunk.dropna(inplace=True)
            # Sample proportionally from this chunk
            n_take = min(n_per_file // 10 + 1, len(chunk))
            collected.append(chunk.sample(n=n_take, random_state=42))
            total_read += len(chunk)
            # Stop early once we have enough
            if sum(len(c) for c in collected) >= n_per_file * 2:
                break
        df = pd.concat(collected, ignore_index=True)
        if len(df) > n_per_file:
            df = df.sample(n=n_per_file, random_state=42)
        return df
    except UnicodeDecodeError:
        return sample_csv_chunked(path, n_per_file, label_candidates, 'latin-1')
    except Exception as e:
        print(f'   ⚠️  {path.name}: {e}')
        return None


def load_dataset_safe(directory, name, max_total, rows_per_csv=15_000,
                      label_candidates=None):
    """
    Memory-safe loader:
    - Parquet: load then sample
    - CSV: chunked read, sample per file — never full load
    """
    if label_candidates is None:
        label_candidates = LABEL_CANDIDATES
    directory = Path(directory)
    parquet_files = sorted(directory.rglob('*.parquet'))
    csv_files     = sorted(directory.rglob('*.csv'))
    print(f'   {len(parquet_files)} parquet + {len(csv_files)} CSV files')

    dfs = []

    # ── Parquet: sample n per file ─────────────────────
    if parquet_files:
        n_per_pq = max_total // len(parquet_files) if parquet_files else max_total
        for f in parquet_files:
            try:
                df = sample_parquet(f, n_per_pq, label_candidates)
                dfs.append(df)
                print(f'   ✅ {f.name}: sampled {len(df):,}')
            except Exception as e:
                print(f'   ❌ {f.name}: {e}')

    # ── CSV: chunked read, sample per file ─────────────
    if csv_files:
        for f in csv_files:
            df = sample_csv_chunked(f, rows_per_csv, label_candidates)
            if df is not None:
                dfs.append(df)
                print(f'   ✅ {f.name}: sampled {len(df):,}')

    if not dfs:
        print(f'   ❌ Nothing loaded from {directory}')
        return None

    raw = pd.concat(dfs, ignore_index=True)
    del dfs  # free memory immediately
    import gc; gc.collect()

    # Find label column
    label_col = next((c for c in label_candidates if c in raw.columns), None)
    if label_col is None:
        print(f'   ⚠️  No label found. Cols: {list(raw.columns)[:8]}')
        return None
    raw.rename(columns={label_col: 'Label'}, inplace=True)
    print(f'   📋 Label: "{label_col}" | Rows: {len(raw):,}')
    return raw


