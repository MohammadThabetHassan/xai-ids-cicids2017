def clean_dataset(raw, max_samples=None, dataset_name='dataset'):
    """Clean: drop NaN/inf/duplicates, encode label, return X, y, le."""
    print(f'   Raw shape: {raw.shape}')
    raw.replace([np.inf, -np.inf], np.nan, inplace=True)
    raw.dropna(inplace=True)
    raw.drop_duplicates(inplace=True)

    # Columns to always drop (IDs, timestamps, IPs, and any label-leakage columns)
    ALWAYS_DROP = [
        'Flow ID', 'Source IP', 'Destination IP', 'Src IP',
        'Dst IP', 'Source Port', 'Destination Port',
        'Timestamp', 'timestamp', 'proto', 'service', 'state',
        'id', 'srcip', 'dstip',
        # Leakage — these ARE the label encoded differently
        'label', 'label_val', 'attack', 'attack_cat',
        'is_attack', 'class', 'target',
    ]
    drop_cols = [c for c in ALWAYS_DROP if c in raw.columns and c != 'Label']

    X = raw.drop(columns=['Label'] + drop_cols, errors='ignore')

    # Convert object columns to numeric where possible (fixes CICIDS2018 string cols)
    for col in X.select_dtypes(include=['object']).columns:
        X[col] = pd.to_numeric(X[col], errors='coerce')
    X = X.select_dtypes(include=[np.number])

    # Drop columns with all-zero variance (useless features)
    zero_var = X.columns[X.std() == 0].tolist()
    if zero_var:
        X = X.drop(columns=zero_var)
        print(f'   Dropped {len(zero_var)} zero-variance columns')

    # Drop any remaining NaN introduced by to_numeric
    X.replace([np.inf, -np.inf], np.nan, inplace=True)
    mask = X.notna().all(axis=1)
    X = X[mask].reset_index(drop=True)
    y = raw['Label'].astype(str).str.strip()[mask].reset_index(drop=True)

    if max_samples and len(X) > max_samples:
        idx = np.random.choice(len(X), max_samples, replace=False)
        X = X.iloc[idx].reset_index(drop=True)
        y = y.iloc[idx].reset_index(drop=True)

    le = LabelEncoder()
    y_enc = le.fit_transform(y)
    print(f'   Clean shape: {X.shape} | Classes: {list(le.classes_)}')
    return X, y_enc, le


LABEL_CANDIDATES = [
    'Label', 'label', ' Label', 'attack_cat',
