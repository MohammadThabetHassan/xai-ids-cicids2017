from sklearn.preprocessing import LabelEncoder

def prepare_dataset(ds, name):
    X = ds['X'][ds['features']].values
    y = ds['y']

    # ── Encode string labels to integers first ──
    le = LabelEncoder()
    y_enc = le.fit_transform(y)
    ds['le'] = le
    n_classes = len(le.classes_)
    print(f'    {name} — Classes: {n_classes} → {list(le.classes_)}')

    scaler = RobustScaler()
    X_scaled = scaler.fit_transform(X)

    # ── Stratified split BEFORE SMOTE ──
    X_tr, X_te, y_tr, y_te = train_test_split(
        X_scaled, y_enc, test_size=TEST_SIZE,
        random_state=RANDOM_STATE, stratify=y_enc
    )

    print(f'    {name} — Train classes: {len(np.unique(y_tr))}  Test classes: {len(np.unique(y_te))}')

    if n_classes < 2:
        print(f'    ⚠️  {name} has < 2 classes — skipping SMOTE')
        joblib.dump(scaler, OUT/f'models/scaler_{name}.joblib')
        return X_tr, X_te, y_tr, y_te, scaler

    # ── SMOTE only on training set ──
    cc = Counter(y_tr)
    target = max(500, int(np.median(list(cc.values()))))
    strat  = {c: min(v, min(target, 3000)) for c, v in cc.items() if v < target}

    if strat:
        try:
            sm = SMOTE(sampling_strategy=strat, random_state=42)
            X_tr, y_tr = sm.fit_resample(X_tr, y_tr)
            print(f'    {name} → SMOTE applied, train: {len(X_tr):,}')
        except Exception as e:
            print(f'    {name} → SMOTE skipped: {e}')

    joblib.dump(scaler, OUT/f'models/scaler_{name}.joblib')
    return X_tr, X_te, y_tr, y_te, scaler


for name, ds in DATASETS.items():
    print(f'\n🔧  Preparing {name}...')
    X_tr, X_te, y_tr, y_te, scaler = prepare_dataset(ds, name)
    DATASETS[name].update({
        'X_train': X_tr, 'X_test': X_te,
        'y_train': y_tr, 'y_test': y_te,
        'scaler':  scaler
    })
    print(f'    Train: {len(X_tr):,}  Test: {len(X_te):,}')

