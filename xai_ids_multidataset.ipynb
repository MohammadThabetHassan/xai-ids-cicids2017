FASTAPI_CODE = f'''
import joblib, json, numpy as np
from fastapi import FastAPI, HTTPException
from pydantic import BaseModel
from typing import List, Optional
import shap

app = FastAPI(
    title="XAI-IDS: Explainable Intrusion Detection",
    description="Multi-dataset XAI-IDS | XGBoost + SHAP/LIME | Research Paper Grade",
    version="2.0.0",
)

# Load artifacts
model    = joblib.load("model/xgb_{primary_ds}.joblib")
scaler   = joblib.load("model/scaler_{primary_ds}.joblib")
le       = joblib.load("model/label_encoder_{primary_ds}.joblib")
features = joblib.load("model/features_{primary_ds}.joblib")
explainer = shap.TreeExplainer(model)
with open("model/model_metadata.json") as f:
    meta = json.load(f)


class FlowFeatures(BaseModel):
    features: List[float]
    explain: bool = True

class Prediction(BaseModel):
    prediction: str
    confidence: float
    probabilities: dict
    shap_top10: Optional[dict] = None
    is_attack: bool


@app.get("/")
def root():
    return meta

@app.post("/predict", response_model=Prediction)
def predict(data: FlowFeatures):
    if len(data.features) != len(features):
        raise HTTPException(422, f"Expected {{len(features)}} features, got {{len(data.features)}}")
    X = np.array(data.features).reshape(1, -1)
    Xs = scaler.transform(X)
    pred_id = model.predict(Xs)[0]
    proba   = model.predict_proba(Xs)[0]
    pred_cls = le.classes_[pred_id]
    proba_dict = {{le.classes_[i]: float(p) for i, p in enumerate(proba)}}

    shap_dict = None
    if data.explain:
        sv = explainer.shap_values(Xs)
        if isinstance(sv, list): sv_arr = sv[pred_id][0]
        elif sv.ndim == 3:       sv_arr = sv[0, :, pred_id]
        else:                    sv_arr = sv[0]
        top_idx   = np.argsort(np.abs(sv_arr))[::-1][:10]
        shap_dict = {{features[i]: float(sv_arr[i]) for i in top_idx}}

    return Prediction(
        prediction=pred_cls,
        confidence=float(proba[pred_id]),
        probabilities=proba_dict,
        shap_top10=shap_dict,
        is_attack=(pred_cls != "BENIGN" and pred_cls.lower() not in ["normal", "benign"]),
    )

@app.get("/health")
def health():
    return {{"status": "ok", "primary_dataset": "{primary_ds}"}}
'''

