def select_features(X, y, k=20, label='dataset'):
    """ANOVA top-30 → quick XGBoost → SHAP top-k."""
    n_avail = X.shape[1]
    k_actual = min(k, n_avail)  # can't select more than we have
    k_anova  = min(30, n_avail)
    print(f'   Feature selection for {label} ({n_avail} features → {k_actual})...')

    if n_avail <= 2:
        print(f'   ⚠️  Only {n_avail} features — skipping selection, using all')
        imp = pd.Series(np.ones(n_avail), index=X.columns)
        return X.columns.tolist(), imp

    # Stage 1: ANOVA
    n_sample = min(150_000, len(X))
    idx = np.random.choice(len(X), n_sample, replace=False)
    sel = SelectKBest(f_classif, k=k_anova)
    sel.fit(X.iloc[idx], y[idx])
    top30_cols = X.columns[sel.get_support()].tolist()

    # Stage 2: Quick XGBoost + SHAP
    Xs = X[top30_cols].iloc[idx]
    ys = y[idx]
    xgb_q = xgb.XGBClassifier(
        n_estimators=100, max_depth=6, n_jobs=-1,
        random_state=42,
        eval_metric='mlogloss', verbosity=0
    )
    xgb_q.fit(Xs[:int(n_sample*0.8)], ys[:int(n_sample*0.8)])

    exp = shap.TreeExplainer(xgb_q)
    sv  = exp.shap_values(Xs[:2000])
    if isinstance(sv, list):
        mean_shap = np.mean([np.abs(s).mean(0) for s in sv], axis=0)
    elif sv.ndim == 3:
        mean_shap = np.abs(sv).mean(axis=(0, 2))
    else:
        mean_shap = np.abs(sv).mean(0)

    imp = pd.Series(mean_shap, index=top30_cols).sort_values(ascending=False)
    top_features = imp.head(k_actual).index.tolist()
    print(f'   ✅ Top {len(top_features)} features selected')
    return top_features, imp


