ALL_RESULTS = {}

for name, ds in DATASETS.items():
    print(f'\n{"="*60}')
    print(f'  Training on {name}')
    print(f'{"="*60}')
    X_tr, X_te = ds['X_train'], ds['X_test']
    y_tr, y_te = ds['y_train'], ds['y_test']
    le = ds['le']

    results = {}

    # ── Sanity check ──
    if len(np.unique(y_tr)) < 2:
        print(f'  ❌ {name} has < 2 classes — skipping!')
        continue

    # ── Auto-detect binary vs multiclass ──
    n_cls     = len(np.unique(y_tr))
    objective = 'binary:logistic' if n_cls == 2 else 'multi:softprob'
    metric    = 'logloss'         if n_cls == 2 else 'mlogloss'
    print(f'  ℹ️  {n_cls} classes → objective={objective}')

    # ── XGBoost ────────────────────────────────────
    print('  🎯 XGBoost...')
    xgb_m = xgb.XGBClassifier(
        n_estimators=XGB_EPOCHS, max_depth=8, learning_rate=0.1,
        subsample=0.8, colsample_bytree=0.8,
        reg_alpha=0.1, reg_lambda=1.0, min_child_weight=3,
        tree_method=tree_method, device=device, n_jobs=-1,
        random_state=42,
        objective=objective,
        eval_metric=metric,
        early_stopping_rounds=PATIENCE,
        verbosity=0
    )
    xgb_m.fit(
        X_tr, y_tr,
        eval_set=[(X_te, y_te)],
        verbose=False,
    )
    p = xgb_m.predict(X_te)
    results['XGBoost'] = {
        'model': xgb_m, 'pred': p,
        'acc': accuracy_score(y_te, p),
        'f1':  f1_score(y_te, p, average='weighted'),
        'precision': precision_score(y_te, p, average='weighted', zero_division=0),
        'recall': recall_score(y_te, p, average='weighted', zero_division=0),
    }
    print(f'     Acc={results["XGBoost"]["acc"]:.4f}  F1={results["XGBoost"]["f1"]:.4f}')
    joblib.dump(xgb_m, OUT/f'models/xgb_{name}.joblib')

    # ── Random Forest ──────────────────────────────
    print('  🌲 Random Forest...')
    rf_m = RandomForestClassifier(
        n_estimators=200, max_depth=20,
        min_samples_split=5, class_weight='balanced',
        n_jobs=-1, random_state=42
    )
    rf_m.fit(X_tr, y_tr)
    p = rf_m.predict(X_te)
    results['RandomForest'] = {
        'model': rf_m, 'pred': p,
        'acc': accuracy_score(y_te, p),
        'f1':  f1_score(y_te, p, average='weighted'),
        'precision': precision_score(y_te, p, average='weighted', zero_division=0),
        'recall': recall_score(y_te, p, average='weighted', zero_division=0),
    }
    print(f'     Acc={results["RandomForest"]["acc"]:.4f}  F1={results["RandomForest"]["f1"]:.4f}')
    joblib.dump(rf_m, OUT/f'models/rf_{name}.joblib')

    # ── LightGBM ───────────────────────────────────
    print('  ⚡ LightGBM...')
    lgb_m = lgb.LGBMClassifier(
        n_estimators=300, max_depth=8, learning_rate=0.1,
        subsample=0.8, colsample_bytree=0.8,
        class_weight='balanced', n_jobs=-1,
        random_state=42, verbosity=-1
    )
    lgb_m.fit(X_tr, y_tr,
        eval_set=[(X_te, y_te)],
        callbacks=[lgb.early_stopping(20, verbose=False)]
    )
    p = lgb_m.predict(X_te)
    results['LightGBM'] = {
        'model': lgb_m, 'pred': p,
        'acc': accuracy_score(y_te, p),
        'f1':  f1_score(y_te, p, average='weighted'),
        'precision': precision_score(y_te, p, average='weighted', zero_division=0),
        'recall': recall_score(y_te, p, average='weighted', zero_division=0),
    }
    print(f'     Acc={results["LightGBM"]["acc"]:.4f}  F1={results["LightGBM"]["f1"]:.4f}')
    joblib.dump(lgb_m, OUT/f'models/lgb_{name}.joblib')

    # ── Voting Ensemble ────────────────────────────
    print('  🗳️  Ensemble...')
    xgb_ens = xgb.XGBClassifier(
        n_estimators=xgb_m.best_iteration + 1,
        max_depth=8, learning_rate=0.1,
        subsample=0.8, colsample_bytree=0.8,
        reg_alpha=0.1, reg_lambda=1.0, min_child_weight=3,
        tree_method=tree_method, device=device, n_jobs=-1,
        random_state=42,
        objective=objective,
        eval_metric=metric,
        verbosity=0
        # NO early_stopping_rounds
    )
    ens = VotingClassifier(
        estimators=[('xgb', xgb_ens), ('rf', rf_m), ('lgb', lgb_m)],
        voting='soft', n_jobs=-1
    )
    ens.fit(X_tr, y_tr)
    p = ens.predict(X_te)
    results['Ensemble'] = {
        'model': ens, 'pred': p,
        'acc': accuracy_score(y_te, p),
        'f1':  f1_score(y_te, p, average='weighted'),
        'precision': precision_score(y_te, p, average='weighted', zero_division=0),
        'recall': recall_score(y_te, p, average='weighted', zero_division=0),
    }
    print(f'     Acc={results["Ensemble"]["acc"]:.4f}  F1={results["Ensemble"]["f1"]:.4f}')
    joblib.dump(ens, OUT/f'models/ensemble_{name}.joblib')

    ALL_RESULTS[name] = results
