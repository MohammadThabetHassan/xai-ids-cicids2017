def compute_xcs(model, explainer, lime_explainer,
                X_sample, y_sample, le, features,
                k=5, n_neighbours=10,
                w1=0.4, w2=0.3, w3=0.3):
    """
    Compute XAI Confidence Score (XCS) for each sample.
    Returns DataFrame with columns:
      sample_id, true_class, pred_class, correct,
      confidence, shap_instability, jaccard_sl, xcs, flag_review
    """
    records = []
    proba_all = model.predict_proba(X_sample)
    preds_all = model.predict(X_sample)

    # SHAP for all samples
    sv_all = explainer.shap_values(X_sample)

    for i in range(len(X_sample)):
        pred_id  = int(preds_all[i])
        true_id  = int(y_sample[i])
        conf     = float(proba_all[i, pred_id])

        # ── SHAP for this sample ──────────────────────
        if isinstance(sv_all, list):
            sv_i = sv_all[pred_id][i]
        elif sv_all.ndim == 3:
            sv_i = sv_all[i, :, pred_id]
        else:
            sv_i = sv_all[i]

        shap_top_k = set(
            pd.Series(np.abs(sv_i), index=features).nlargest(k).index
        )

        # ── SHAP instability (over k neighbours) ─────
        noise_std = 0.05
        neighbour_svs = []
        for _ in range(n_neighbours):
            x_noisy = X_sample[i] + np.random.normal(0, noise_std, X_sample[i].shape)
            sv_n = explainer.shap_values(x_noisy.reshape(1, -1))
            if isinstance(sv_n, list):
                sv_ni = sv_n[pred_id][0]
            elif sv_n.ndim == 3:
                sv_ni = sv_n[0, :, pred_id]
            else:
                sv_ni = sv_n[0]
            neighbour_svs.append(np.abs(sv_ni))

        instab_raw = float(np.std(neighbour_svs))
        instab_norm = min(instab_raw / (np.mean(np.abs(sv_i)) + 1e-9), 1.0)

        # ── LIME top-K for this sample ─────────────────
        try:
            lime_exp = lime_explainer.explain_instance(
                X_sample[i], model.predict_proba,
                num_features=k, labels=(pred_id,),
                num_samples=200
            )
            lime_weights = dict(lime_exp.as_list(label=pred_id))
            lime_top_k = set(
                pd.Series({kk: abs(v) for kk, v in lime_weights.items()})
                .nlargest(k).index
            )
        except Exception:
            lime_top_k = set()

        # ── Jaccard SHAP–LIME ──────────────────────────
        if shap_top_k | lime_top_k:
            jaccard_sl = len(shap_top_k & lime_top_k) / len(shap_top_k | lime_top_k)
        else:
            jaccard_sl = 0.0

        # ── XCS ───────────────────────────────────────
        xcs = w1 * conf + w2 * (1.0 - instab_norm) + w3 * jaccard_sl

        records.append({
            'sample_id':        i,
            'true_class':       le.classes_[true_id] if true_id < len(le.classes_) else str(true_id),
            'pred_class':       le.classes_[pred_id],
            'correct':          pred_id == true_id,
            'confidence':       round(conf, 4),
            'shap_instability': round(instab_norm, 4),
            'jaccard_sl':       round(jaccard_sl, 4),
            'xcs':              round(xcs, 4),
            'flag_review':      xcs < 0.5,
        })

    return pd.DataFrame(records)


# ── Run XCS on each dataset ───────────────────────
XCS_RESULTS = {}
N_XCS_SAMPLES = 100  # keep small — LIME per sample is slow

for name, ds in DATASETS.items():
    print(f'\n🆕 Computing XCS: {name} ({N_XCS_SAMPLES} samples)...')
    sd       = SHAP_DATA.get(name)
    ld       = LIME_DATA.get(name)
    if not sd or not ld:
        print(f'   Skipping (SHAP/LIME not computed yet)')
        continue

    le       = ds['le']
    model    = ds['best_model']
    features = ds['features']
    X_te     = ds['X_test']
    y_te     = ds['y_test']
    explainer= sd['explainer']

    # Rebuild LIME explainer if needed
    lime_exp = lime.lime_tabular.LimeTabularExplainer(
        training_data=ds['X_train'][:3000],
        feature_names=features,
        class_names=list(le.classes_),
        mode='classification',
        discretize_continuous=True,
        random_state=42,
    )

    # Sample stratified across classes
    idx = []
    for cls in np.unique(y_te):
        cls_idx = np.where(y_te == cls)[0]
        n = max(1, N_XCS_SAMPLES // len(np.unique(y_te)))
        idx.extend(cls_idx[:n].tolist())
    idx = idx[:N_XCS_SAMPLES]

    xcs_df = compute_xcs(
        model, explainer, lime_exp,
        X_te[idx], y_te[idx], le, features,
        k=5, n_neighbours=5
    )
    XCS_RESULTS[name] = xcs_df
    xcs_df.to_csv(OUT/f'explanations/xcs_{name}.csv', index=False)

    # Summary stats
    print(f'   Mean XCS         : {xcs_df["xcs"].mean():.3f}')
    print(f'   Flagged for review: {xcs_df["flag_review"].sum()} / {len(xcs_df)}')
    correct_xcs   = xcs_df[xcs_df['correct']]['xcs'].mean()
    incorrect_xcs = xcs_df[~xcs_df['correct']]['xcs'].mean()
    print(f'   Mean XCS (correct pred)  : {correct_xcs:.3f}')
    print(f'   Mean XCS (wrong pred)    : {incorrect_xcs:.3f}  ← should be lower')

    # XCS distribution plot
    fig, axes = plt.subplots(1, 2, figsize=(13, 4))

    # Histogram
    axes[0].hist(xcs_df[xcs_df['correct']]['xcs'], bins=20,
                 alpha=0.7, color='#2ECC71', label='Correct prediction')
    axes[0].hist(xcs_df[~xcs_df['correct']]['xcs'], bins=20,
                 alpha=0.7, color='#E74C3C', label='Wrong prediction')
    axes[0].axvline(0.5, color='gray', linestyle='--', linewidth=1, label='Flag threshold (0.5)')
    axes[0].set_title(f'{name} — XCS Distribution', fontsize=11)
    axes[0].set_xlabel('XCS score')
    axes[0].legend(fontsize=9)

    # Per-class mean XCS
    per_class = xcs_df.groupby('pred_class')['xcs'].mean().sort_values()
    per_class.plot(kind='barh', ax=axes[1], color='#3B7DC8')
    axes[1].axvline(0.5, color='gray', linestyle='--', linewidth=1)
    axes[1].set_title(f'{name} — Mean XCS per Attack Class', fontsize=11)
    axes[1].set_xlabel('Mean XCS')

    plt.tight_layout()
    plt.savefig(OUT/f'plots/xcs_{name}.png', dpi=150, bbox_inches='tight')
    plt.show()

    # XCS vs confidence scatter
    plt.figure(figsize=(7, 5))
    colors = xcs_df['correct'].map({True: '#2ECC71', False: '#E74C3C'})
    plt.scatter(xcs_df['confidence'], xcs_df['xcs'], c=colors, alpha=0.6, s=40)
    plt.axhline(0.5, color='gray', linestyle='--', linewidth=0.8)
    plt.xlabel('Model Confidence')
    plt.ylabel('XCS Score')
    plt.title(f'{name} — XCS vs Model Confidence', fontsize=11)
    from matplotlib.patches import Patch
    plt.legend(handles=[
        Patch(color='#2ECC71', label='Correct'),
        Patch(color='#E74C3C', label='Wrong')
    ])
    plt.tight_layout()
    plt.savefig(OUT/f'plots/xcs_scatter_{name}.png', dpi=150, bbox_inches='tight')
    plt.show()

print('\n✅ XCS computation complete')
print('   KEY FINDING: XCS should be significantly lower for wrong predictions')
print('   This validates XCS as a trustworthiness signal for security analysts')





import json
import numpy as np

# Custom encoder to handle numpy types
class NpEncoder(json.JSONEncoder):
    def default(self, o):
        if isinstance(o, np.integer): return int(o)
        if isinstance(o, np.floating): return float(o)
        if isinstance(o, np.ndarray): return o.tolist()
        return super().default(o)

# Final metadata for the paper and FastAPI
metadata = {
    'project': 'XAI-IDS: Explainable AI Intrusion Detection',
    'repo': 'MohammadThabetHassan/xai-ids-cicids2017',
    'xai_methods': ['SHAP TreeExplainer', 'LIME TabularExplainer'],
    'models': ['XGBoost', 'RandomForest', 'LightGBM', 'VotingEnsemble'],
    'datasets': {},
    'cross_dataset_jaccard': float(jac_df['jaccard'].mean()) if not jac_df.empty else None,
}

for name, ds in DATASETS.items():
    res = ALL_RESULTS[name]
    metadata['datasets'][name] = {
        'n_features_selected': len(ds['features']),
        'features': ds['features'],
        'n_classes': len(ds['le'].classes_),
        'classes': [str(c) for c in ds['le'].classes_],   # ← fix: cast to str
        'results': {
            m: {'accuracy': float(r['acc']), 'f1': float(r['f1']),
                'precision': float(r['precision']), 'recall': float(r['recall'])}
            for m, r in res.items() if m != 'pred'
        }
    }
    joblib.dump(ds['le'], OUT/f'models/label_encoder_{name}.joblib')
    joblib.dump(ds['features'], OUT/f'models/features_{name}.joblib')

with open(OUT/'model_metadata.json', 'w') as f:
    json.dump(metadata, f, indent=2, cls=NpEncoder)   # ← fix: use NpEncoder

